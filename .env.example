PORT=3000
NODE_ENV=development
API_KEY=your-secret-api-key

# Redis caching (Upstash) — set to true to enable, false (or omit) to disable
# When disabled the app works normally but scrapers run on every request
REDIS_ENABLED=false
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token